    {
      "id": "bcfc8c41-71b6-41bf-a595-ba334890a213",
      "name": "5. Login – Admin-Created Agent Login (Should Succeed)",
      "request": {
        "url": {
          "path": [
            "auth",
            "v1",
            "token"
          ],
          "host": [
            "{{SUPABASE_URL}}"
          ],
