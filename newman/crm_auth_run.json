    {
      "id": "18a6b038-94bc-4aef-af4f-e37dc231c7ab",
      "name": "6. Read Own Profile from public.users",
      "request": {
        "url": {
          "path": [
            "rest",
            "v1",
            "users"
          ],
          "host": [
            "{{SUPABASE_URL}}"
          ],
          "query": [
            {
              "key": "select",
              "value": "id,email,full_name,role,manager_id,created_at"
            }
          ],
          "variable": []
        },
        "header": [
          {
            "key": "apikey",
            "value": "{{SUPABASE_ANON_KEY}}"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{ACCESS_TOKEN}}"
          }
        ],
        "method": "GET"
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "id": "66b81a77-fd19-4bab-a0e7-d6a7f0e00311",
            "type": "text/javascript",
            "exec": [
              "pm.test('Profile fetch returns 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "var body = pm.response.json();",
              "pm.test('Profile is an array with at least 1 user', function () {",
              "    pm.expect(body).to.be.an('array').and.have.length.above(0);",
              "});",
              "",
              "if (body.length > 0) {",
              "    pm.test('Profile has email field', function () {",
              "        pm.expect(body[0]).to.have.property('email');",
              "    });",
              "    pm.test('Profile has role field', function () {",
              "        pm.expect(body[0]).to.have.property('role');",
              "        pm.expect(['agent','manager','super_admin']).to.include(body[0].role);",
              "    });",
              "}"
            ],
            "_lastExecutionId": "8abb3211-89c9-45f3-8118-c62bf6b87e09"
          }
        }
      ]
    },
